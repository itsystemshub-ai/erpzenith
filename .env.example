# ─── ERP ZENITH - Variables de Entorno Globales ──────────────────────────────
# Copiar este archivo como .env.local y rellenar con tus valores reales

# ─── Backend URL ─────────────────────────────────────────────────────────────
BACKEND_URL="http://localhost:3001"

# ─── Firebase (Opcional - Solo si usas Firebase) ────────────────────────────
# NEXT_PUBLIC_FIREBASE_API_KEY="tu-api-key"
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="tu-proyecto.firebaseapp.com"
# NEXT_PUBLIC_FIREBASE_PROJECT_ID="tu-proyecto"
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="tu-bucket"
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="tu-sender-id"
# NEXT_PUBLIC_FIREBASE_APP_ID="tu-app-id"
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# ─── Netlify (Opcional - Solo para deploy en Netlify) ───────────────────────
# NETLIFY_SITE_ID="tu-site-id"
# NETLIFY_API_TOKEN="tu-api-token"
