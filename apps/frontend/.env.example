# ─── API URL ─────────────────────────────────────────────────────────────────
# Local: usa las API routes de Next.js (proxy)
# Producción (Vercel): usa la URL directa de tu backend en Render/Railway
# Ejemplo: NEXT_PUBLIC_API_URL=https://erpzenith-backend.onrender.com/api
NEXT_PUBLIC_API_URL="/api"

# ─── Backend URL (para API routes en Vercel) ─────────────────────────────────
# Solo usado en server-side (Vercel functions)
# Ejemplo: BACKEND_URL=https://erpzenith-backend.onrender.com
BACKEND_URL="http://localhost:3001"

# ─── Supabase (opcional - si usas Supabase directamente) ────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://nmhxxmvvbgqnodlfetil.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_MVNOgxFnLftFJbrwmftwEg_EWoVcCHt
