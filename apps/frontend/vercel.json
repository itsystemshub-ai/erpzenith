{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && npm install",
  "buildCommand": "cd ../.. && npm run build",
  "outputDirectory": ".next",
  "functions": {
    "src/app/api/[[...path]]/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
