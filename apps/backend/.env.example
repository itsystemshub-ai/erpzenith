# Variables de Entorno del Backend

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://neondb_owner:npg_LeDj32kEGRxf@ep-winter-smoke-anm2584k-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ─────────────────────────────────────────────────────────────────────────────
# JWT & SEGURIDAD
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET="super-secret-jwt-key-min-32-characters-long-xyz123"
JWT_REFRESH_SECRET="another-super-secret-refresh-key-min-32-chars-abc456"
JWT_EXPIRES_IN="8h"

# ─────────────────────────────────────────────────────────────────────────────
# CLOUDFLARE R2 (Almacenamiento de Archivos)
# ─────────────────────────────────────────────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY_ID="your-r2-access-key-id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
CLOUDFLARE_R2_ENDPOINT="https://account-id.r2.cloudflarestorage.com"
CLOUDFLARE_R2_BUCKET="erp-files"
CLOUDFLARE_R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# ─────────────────────────────────────────────────────────────────────────────
# INTELIGENCIA ARTIFICIAL
# ─────────────────────────────────────────────────────────────────────────────
# OpenRouter (proveedor preferido - accede a GPT-4o, Claude, Gemini y más)
# Obtén tu clave gratis en: https://openrouter.ai/keys
OPENROUTER_API_KEY="your-openrouter-api-key"
# Modelo a usar. Ver todos los modelos en: https://openrouter.ai/models
OPENROUTER_MODEL="openai/gpt-4o"
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_SITE_TITLE="ERP ZENITH"

# Google Gemini (fallback si OpenRouter no está configurado)
GEMINI_API_KEY="your-gemini-api-key"
HF_TOKEN="your-huggingface-token"
GROQ_API_KEY="your-groq-api-key"

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (SMTP)
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="erp@empresa.com"
SMTP_PASS="your-app-password"
SMTP_FROM="ERP ZENITH <erp@empresa.com>"

# ─────────────────────────────────────────────────────────────────────────────
# N8N (Automatización)
# ─────────────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL="https://n8n.cloud/webhook"
N8N_API_KEY="your-n8n-api-key"

# ─────────────────────────────────────────────────────────────────────────────
# APLICACIÓN
# ─────────────────────────────────────────────────────────────────────────────
PORT="3001"
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:3001"

# ─────────────────────────────────────────────────────────────────────────────
# REDIS (Cache y Colas) - OPCIONAL
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ─────────────────────────────────────────────────────────────────────────────
# ENCRYPTACIÓN
# ─────────────────────────────────────────────────────────────────────────────
ENCRYPTION_KEY="32-byte-encryption-key-here-xyz"
