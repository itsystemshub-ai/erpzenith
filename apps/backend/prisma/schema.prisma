generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  username             String                @unique
  passwordHash         String
  name                 String
  firstName            String
  lastName             String
  cedula               String                @unique
  phone                String?
  avatar               String?
  roleId               String
  isActive             Boolean               @default(true)
  isVerified           Boolean               @default(false)
  lastLogin            DateTime?
  lastLoginIP          String?
  failedAttempts       Int                   @default(0)
  lockedUntil          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  mfaEnabled           Boolean               @default(false)
  mfaSecret            String?
  aiUsageLogs          AIUsageLog[]
  accessAttempts       AccessAttempt[]
  auditLogs            AuditLog[]
  chatbotConversations ChatbotConversation[]
  Employee             Employee?
  inventoryMovements   InventoryMovement[]
  notifications        Notification[]
  posSessions          POSSession[]
  passwordHistory      PasswordHistory[]
  purchases            Purchase[]
  quotes               Quote[]
  sales                Sale[]
  securityAlerts       SecurityAlert[]
  sessions             Session[]
  role                 Role                  @relation(fields: [roleId], references: [id])
  userActivities       UserActivity[]

  @@index([email])
  @@index([roleId])
  @@index([isActive])
  @@index([cedula])
}

model Role {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  color       String         @default("#6366f1")
  icon        String         @default("shield")
  isSystem    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  modules     ModuleAccess[] @relation("RoleModuleAccess")
  permissions Permission[]
  users       User[]

  @@index([name])
}

model Permission {
  id        String   @id @default(cuid())
  roleId    String
  module    String
  action    String
  resource  String?
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action, resource])
  @@index([roleId])
  @@index([module])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  refreshToken String?
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  module     String
  entityType String?
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
}

model CompanyConfig {
  id                 String   @id @default(cuid())
  businessName       String
  rif                String
  address            String
  phone              String?
  email              String?
  logoUrl            String?
  fiscalYear         String   @default("ENERO-DICIEMBRE")
  currency           String   @default("VES")
  taxRate            Float    @default(0.16)
  invoicePrefix      String   @default("F")
  invoiceControl     String   @default("00-00000001")
  invoiceSeries      String   @default("A")
  nextInvoiceNum     Int      @default(1)
  checkStock         Boolean  @default(true)
  allowNegativeStock Boolean  @default(false)
  valuationMethod    String   @default("PROMEDIO")
  updatedAt          DateTime @updatedAt

  @@index([rif])
}

model SystemConfig {
  id         String   @id @default(cuid())
  key        String   @unique
  value      String
  type       String   @default("string")
  group      String
  label      String
  isPublic   Boolean  @default(false)
  isEditable Boolean  @default(true)
  updatedAt  DateTime @updatedAt
  updatedBy  String?

  @@index([group])
  @@index([key])
}

model Customer {
  id                 String              @id @default(cuid())
  businessName       String
  rif                String              @unique
  address            String?
  phone              String?
  email              String?
  creditLimit        Float?
  creditDays         Int?
  isContributor      Boolean             @default(true)
  hasSpecialTax      Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  accountReceivables AccountReceivable[]
  creditNotes        CreditNote[]
  quotes             Quote[]
  sales              Sale[]

  @@index([rif])
  @@index([email])
}

model Supplier {
  id                  String               @id @default(cuid())
  businessName        String
  rif                 String               @unique
  code                String               @unique
  address             String?
  phone               String?
  email               String?
  website             String?
  contactName         String?
  contactPhone        String?
  contactEmail        String?
  isContributor       Boolean              @default(true)
  hasSpecialTax       Boolean              @default(false)
  bankName            String?
  bankAccount         String?
  bankType            String?
  rating              Float                @default(0)
  isApproved          Boolean              @default(true)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  supplierCategoryId  String?
  accountPayables     AccountPayable[]
  lots                Lot[]
  purchases           Purchase[]
  purchaseOrders      PurchaseOrder[]
  supplierCategory    SupplierCategory?    @relation(fields: [supplierCategoryId], references: [id])
  supplierEvaluations SupplierEvaluation[]

  @@index([rif])
  @@index([code])
}

model Product {
  id                   String                @id @default(cuid())
  code                 String                @unique
  barcode              String?               @unique
  name                 String
  description          String?
  cost                 Float
  price                Float
  stock                Float                 @default(0)
  minStock             Float                 @default(0)
  maxStock             Float?
  isActive             Boolean               @default(true)
  isService            Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  categoryId           String?
  bomComponents        BOMComponent[]        @relation("component")
  billOfMaterials      BillOfMaterial?
  creditNoteItems      CreditNoteItem[]
  inventoryMovements   InventoryMovement[]
  lots                 Lot[]
  mrpRequests          MRPRequest[]
  posQuickProducts     POSQuickProduct[]
  physicalCountItems   PhysicalCountItem[]
  categoryRel          Category?             @relation(fields: [categoryId], references: [id])
  productionConsumed   ProductionConsumed[]  @relation("consumed")
  productionOrders     ProductionOrder[]
  productionResults    ProductionResult[]    @relation("produced")
  purchaseItems        PurchaseItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  purchaseRequestItems PurchaseRequestItem[]
  quoteItems           QuoteItem[]
  saleItems            SaleItem[]
  warehouseStocks      WarehouseStock[]
  workOrderParts       WorkOrderPart[]

  @@index([code])
  @@index([isActive])
}

model Sale {
  id                  String             @id @default(cuid())
  number              String             @unique
  date                DateTime           @default(now())
  customerId          String
  subtotal            Float
  tax                 Float
  total               Float
  status              SaleStatus         @default(DRAFT)
  paymentStatus       PaymentStatus      @default(PENDING)
  invoiceNumber       String?            @unique
  invoiceControl      String?
  invoicePdf          String?
  invoiceXml          String?
  paymentMethod       String?
  paymentDate         DateTime?
  dueDate             DateTime?
  paidAt              DateTime?
  sellerId            String
  commission          Float?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  accountReceivable   AccountReceivable?
  creditNotes         CreditNote[]
  posTransactions     POSTransaction[]
  convertedFromQuotes Quote[]            @relation("SaleConvertedFromQuotes")
  customer            Customer           @relation(fields: [customerId], references: [id])
  seller              User               @relation(fields: [sellerId], references: [id])
  items               SaleItem[]
  salesCommissions    SalesCommission[]

  @@index([customerId])
  @@index([status])
  @@index([date])
  @@index([invoiceNumber])
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  productId String
  quantity  Float
  price     Float
  discount  Float    @default(0)
  taxRate   Float    @default(0.16)
  subtotal  Float
  taxAmount Float
  total     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
}

model Purchase {
  id             String          @id @default(cuid())
  number         String          @unique
  date           DateTime        @default(now())
  supplierId     String
  buyerId        String
  subtotal       Float
  tax            Float
  total          Float
  invoiceNumber  String?
  invoiceDate    DateTime?
  controlNumber  String?
  status         PurchaseStatus  @default(PENDING)
  paymentStatus  PaymentStatus   @default(PENDING)
  dueDate        DateTime?
  paidAt         DateTime?
  receivedBy     String?
  receivedAt     DateTime?
  invoicedBy     String?
  invoicedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accountPayable AccountPayable?
  lots           Lot[]
  buyer          User            @relation(fields: [buyerId], references: [id])
  supplier       Supplier        @relation(fields: [supplierId], references: [id])
  items          PurchaseItem[]
  PurchaseOrder  PurchaseOrder[]

  @@index([supplierId])
  @@index([status])
  @@index([date])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  productId  String
  quantity   Float
  unitCost   Float
  taxRate    Float    @default(0.16)
  subtotal   Float
  taxAmount  Float
  total      Float
  product    Product  @relation(fields: [productId], references: [id])
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([productId])
}

model ModuleAccess {
  id          String   @id @default(cuid())
  roleId      String
  moduleGroup String
  moduleName  String
  canView     Boolean  @default(true)
  canEdit     Boolean  @default(false)
  canDelete   Boolean  @default(false)
  canExport   Boolean  @default(false)
  canReport   Boolean  @default(true)
  createdAt   DateTime @default(now())
  role        Role     @relation("RoleModuleAccess", fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleName])
}






























model Department {
  id              String            @id @default(cuid())
  name            String            @unique
  description     String?
  managerId       String?
  parentId        String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  parent          Department?       @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children        Department[]      @relation("DepartmentHierarchy")
  employees       Employee[]
  PurchaseRequest PurchaseRequest[]

  @@index([parentId])
}

model JobPosition {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  minSalary   Float?
  maxSalary   Float?
  createdAt   DateTime   @default(now())
  employees   Employee[]

  @@index([name])
}

model Employee {
  id                String            @id @default(cuid())
  userId            String?           @unique
  firstName         String
  lastName          String
  cedula            String            @unique
  birthDate         DateTime?
  gender            String?
  nationality       String?
  address           String?
  phone             String?
  email             String?
  departmentId      String?
  positionId        String?
  hireDate          DateTime
  employmentType    EmploymentType
  workSchedule      String?
  salary            Float
  salaryType        SalaryType
  bankAccount       String?
  childrenCount     Int               @default(0)
  hasDisability     Boolean           @default(false)
  isActive          Boolean           @default(true)
  terminationDate   DateTime?
  terminationReason String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  attendances       Attendance[]
  bonuses           Bonus[]
  contracts         Contract[]
  deductions        Deduction[]
  position          JobPosition?      @relation(fields: [positionId], references: [id])
  user              User?             @relation(fields: [userId], references: [id])
  payrollItems      PayrollItem[]
  commissions       SalesCommission[]
  vacations         Vacation[]

  @@index([cedula])
  @@index([departmentId])
  @@index([isActive])
}

model Contract {
  id         String       @id @default(cuid())
  employeeId String
  type       ContractType
  startDate  DateTime
  endDate    DateTime?
  salary     Float
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  employee   Employee     @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model Attendance {
  id            String           @id @default(cuid())
  employeeId    String
  date          DateTime         @db.Date
  checkIn       DateTime?
  checkOut      DateTime?
  checkInLunch  DateTime?
  checkOutLunch DateTime?
  hoursWorked   Float?
  overtimeHours Float?
  nightHours    Float?
  status        AttendanceStatus
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  employee      Employee         @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

model WorkSchedule {
  id                String   @id @default(cuid())
  name              String   @unique
  mondayIn          String?
  mondayOut         String?
  tuesdayIn         String?
  tuesdayOut        String?
  wednesdayIn       String?
  wednesdayOut      String?
  thursdayIn        String?
  thursdayOut       String?
  fridayIn          String?
  fridayOut         String?
  saturdayIn        String?
  saturdayOut       String?
  sundayIn          String?
  sundayOut         String?
  lunchBreakMinutes Int      @default(60)
  createdAt         DateTime @default(now())

  @@index([name])
}

model Vacation {
  id            String         @id @default(cuid())
  employeeId    String
  periodStart   DateTime
  periodEnd     DateTime
  totalDays     Int
  takenDays     Int            @default(0)
  remainingDays Int
  startDate     DateTime?
  endDate       DateTime?
  status        VacationStatus
  bonusDays     Int
  bonusAmount   Float?
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  employee      Employee       @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
}

model Bonus {
  id          String    @id @default(cuid())
  employeeId  String
  type        BonusType
  description String?
  amount      Float
  date        DateTime
  period      String?
  isRecurring Boolean   @default(false)
  createdAt   DateTime  @default(now())
  employee    Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([date])
}

model Deduction {
  id          String        @id @default(cuid())
  employeeId  String
  type        DeductionType
  description String?
  amount      Float
  percentage  Float?
  date        DateTime
  period      String?
  isRecurring Boolean       @default(false)
  createdAt   DateTime      @default(now())
  employee    Employee      @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([date])
}

model Payroll {
  id              String        @id @default(cuid())
  number          String        @unique
  periodStart     DateTime
  periodEnd       DateTime
  paymentDate     DateTime
  totalEmployees  Int
  totalGross      Float
  totalDeductions Float
  totalNet        Float
  status          PayrollStatus
  processedBy     String?
  processedAt     DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  items           PayrollItem[]

  @@index([periodStart, periodEnd])
  @@index([status])
}

model PayrollItem {
  id              String            @id @default(cuid())
  payrollId       String
  employeeId      String
  baseSalary      Float
  overtimePay     Float             @default(0)
  nightBonus      Float             @default(0)
  holidayPay      Float             @default(0)
  bonus           Float             @default(0)
  cestaTicket     Float             @default(0)
  commissions     Float             @default(0)
  otherEarnings   Float             @default(0)
  totalGross      Float
  ivss            Float             @default(0)
  faov            Float             @default(0)
  ince            Float             @default(0)
  islr            Float             @default(0)
  otherDeductions Float             @default(0)
  totalDeductions Float
  netSalary       Float
  paymentMethod   String?
  bankReference   String?
  receiptUrl      String?
  createdAt       DateTime          @default(now())
  employee        Employee          @relation(fields: [employeeId], references: [id])
  payroll         Payroll           @relation(fields: [payrollId], references: [id])
  SalesCommission SalesCommission[]

  @@index([payrollId])
  @@index([employeeId])
}


model SalesCommission {
  id            String       @id @default(cuid())
  employeeId    String
  saleId        String
  rate          Float
  amount        Float
  status        String       @default("PENDING")
  paidAt        DateTime?
  payrollItemId String?
  createdAt     DateTime     @default(now())
  employee      Employee     @relation(fields: [employeeId], references: [id])
  payrollItem   PayrollItem? @relation(fields: [payrollItemId], references: [id])
  sale          Sale         @relation(fields: [saleId], references: [id])

  @@index([employeeId])
  @@index([saleId])
}







model QualityInspection {
  id              String          @id @default(cuid())
  lotId           String
  type            String
  inspectedBy     String
  date            DateTime        @default(now())
  result          String
  parameters      Json
  notes           String?
  nonConformities NonConformity[]
  lot             Lot             @relation(fields: [lotId], references: [id])
}

model NonConformity {
  id               String            @id @default(cuid())
  inspectionId     String
  description      String
  severity         String
  correctiveAction String?
  status           String            @default("OPEN")
  dueDate          DateTime?
  closedAt         DateTime?
  inspection       QualityInspection @relation(fields: [inspectionId], references: [id])
}

model Lot {
  id                 String               @id @default(cuid())
  code               String               @unique
  productId          String
  quantity           Float
  initialQuantity    Float
  manufacturingDate  DateTime?
  expirationDate     DateTime?
  supplierId         String?
  purchaseId         String?
  productionOrderId  String?
  qualityStatus      QualityStatus        @default(PENDING)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  inventoryMovements InventoryMovement[]
  product            Product              @relation(fields: [productId], references: [id])
  productionOrder    ProductionOrder?     @relation(fields: [productionOrderId], references: [id])
  purchase           Purchase?            @relation(fields: [purchaseId], references: [id])
  supplier           Supplier?            @relation(fields: [supplierId], references: [id])
  movements          LotMovement[]
  productionConsumed ProductionConsumed[]
  productionResults  ProductionResult[]
  qualityInspections QualityInspection[]

  @@index([productId])
  @@index([qualityStatus])
  @@index([expirationDate])
}

model SupplierCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  suppliers   Supplier[]

  @@index([name])
}

model PurchaseRequest {
  id              String                @id @default(cuid())
  number          String                @unique
  date            DateTime              @default(now())
  requestedBy     String
  requesterName   String?
  departmentId    String?
  status          PRStatus              @default(PENDING)
  priority        Priority              @default(NORMAL)
  approvedBy      String?
  approvedAt      DateTime?
  rejectedBy      String?
  rejectedAt      DateTime?
  rejectReason    String?
  purchaseOrderId String?
  notes           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  purchaseOrder   PurchaseOrder?
  department      Department?           @relation(fields: [departmentId], references: [id])
  items           PurchaseRequestItem[]

  @@index([status])
  @@index([date])
}

model PurchaseRequestItem {
  id               String          @id @default(cuid())
  requestId        String
  productId        String
  quantity         Float
  estimatedCost    Float?
  description      String?
  approvedQuantity Float?
  createdAt        DateTime        @default(now())
  product          Product         @relation(fields: [productId], references: [id])
  request          PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([productId])
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  number       String              @unique
  date         DateTime            @default(now())
  supplierId   String
  requestId    String?             @unique
  subtotal     Float
  tax          Float
  total        Float
  expectedDate DateTime?
  deliveryDate DateTime?
  status       POStatus            @default(DRAFT)
  approvedBy   String?
  approvedAt   DateTime?
  receivedAt   DateTime?
  purchaseId   String?
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  purchase     Purchase?           @relation(fields: [purchaseId], references: [id])
  request      PurchaseRequest?    @relation(fields: [requestId], references: [id])
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  items        PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
  @@index([date])
}

model PurchaseOrderItem {
  id        String        @id @default(cuid())
  orderId   String
  productId String
  quantity  Float
  received  Float         @default(0)
  unitCost  Float
  taxRate   Float         @default(0.16)
  subtotal  Float
  total     Float
  order     PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product       @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model SupplierEvaluation {
  id            String   @id @default(cuid())
  supplierId    String
  period        String
  qualityScore  Float
  deliveryScore Float
  priceScore    Float
  serviceScore  Float
  totalScore    Float
  notes         String?
  evaluatedBy   String
  createdAt     DateTime @default(now())
  supplier      Supplier @relation(fields: [supplierId], references: [id])

  @@unique([supplierId, period])
  @@index([supplierId])
}

model AccountPayable {
  id             String      @id @default(cuid())
  purchaseId     String      @unique
  supplierId     String
  originalAmount Float
  paidAmount     Float       @default(0)
  balance        Float
  dueDate        DateTime
  status         APStatus    @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  payments       APPayment[]
  purchase       Purchase    @relation(fields: [purchaseId], references: [id])
  supplier       Supplier    @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([status])
  @@index([dueDate])
}

model APPayment {
  id             String         @id @default(cuid())
  payableId      String
  amount         Float
  date           DateTime
  method         String
  reference      String?
  createdAt      DateTime       @default(now())
  payable        AccountPayable @relation(fields: [payableId], references: [id])

  @@index([payableId])
}

model Vehicle {
  id                 String               @id @default(cuid())
  plate              String               @unique
  brand              String
  model              String
  year               Int
  color              String
  vin                String?
  type               String
  capacity           Float
  status             String               @default("ACTIVO")
  driverId           String?
  lastMaintenance    DateTime?
  nextMaintenance    DateTime?
  mileage            Float                @default(0)
  insuranceCompany   String?
  insurancePolicy    String?
  insuranceExpiry    DateTime?
  registrationExpiry DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  fuelLogs           FuelLog[]
  trips              Trip[]
  driver             Driver?              @relation(fields: [driverId], references: [id])
  maintenances       VehicleMaintenance[]
}

model Driver {
  id            String    @id @default(cuid())
  employeeId    String?
  name          String
  license       String
  licenseExpiry DateTime?
  phone         String?
  email         String?
  status        String    @default("ACTIVO")
  createdAt     DateTime  @default(now())
  trips         Trip[]
  vehicles      Vehicle[]
}

model Trip {
  id           String    @id @default(cuid())
  vehicleId    String
  driverId     String
  origin       String
  destination  String
  route        Json?
