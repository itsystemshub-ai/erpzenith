generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Users ───────────────────────────────────────────────────────────

model User {
  id                   String                @id @default(cuid())
  username             String                @unique
  password             String
  name                 String
  roles                Role[]
  empresaId            String?
  empresa              Empresa?              @relation(fields: [empresaId], references: [id])
  isActive             Boolean               @default(true)
  mfaEnabled           Boolean               @default(false)
  mfaSecret            String?
  passwordChangedAt    DateTime              @default(now())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  passwordResetRequests PasswordResetRequest[]

  @@map("users")
}

model PasswordResetRequest {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  newPassword  String   // hash de la contraseña propuesta
  status       String   @default("PENDIENTE") // PENDIENTE | APROBADA | RECHAZADA
  reviewedBy   String?  // username del admin que revisó
  reviewedAt   DateTime?
  createdAt    DateTime @default(now())

  @@map("password_reset_requests")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())

  @@map("roles")
}

model Permission {
  id       String @id @default(cuid())
  module   String
  action   String
  roles    Role[]

  @@unique([module, action])
  @@map("permissions")
}

// ─── Inventario ─────────────────────────────────────────────────────────────

model Producto {
  id          String          @id @default(cuid())
  sku         String
  tipo        String?
  fabricante  String?
  marca       String?
  material    String?
  espesor     String?
  nombre      String
  descripcion String?
  medidas     String?
  unidad      String          @default("UND")
  precioUSD   Decimal         @db.Decimal(12, 2)
  stockMin    Int             @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  stocks      Stock[]
  movimientos MovimientoStock[]
  itemsOC     ItemOrdenCompra[]
  itemsOP     ItemOrdenProduccion[]

  @@map("productos")
}

model Almacen {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String
  ubicacion String?
  isActive  Boolean  @default(true)
  stocks    Stock[]

  @@map("almacenes")
}

model Stock {
  id         String   @id @default(cuid())
  productoId String
  almacenId  String
  cantidad   Int      @default(0)
  producto   Producto @relation(fields: [productoId], references: [id])
  almacen    Almacen  @relation(fields: [almacenId], references: [id])
  updatedAt  DateTime @updatedAt

  @@unique([productoId, almacenId])
  @@map("stocks")
}

model MovimientoStock {
  id          String   @id @default(cuid())
  productoId  String
  tipo        String   // ENTRADA | SALIDA | AJUSTE | TRASLADO
  cantidad    Int
  referencia  String?
  notas       String?
  producto    Producto @relation(fields: [productoId], references: [id])
  createdAt   DateTime @default(now())

  @@map("movimientos_stock")
}

// ─── Compras ─────────────────────────────────────────────────────────────────

model Proveedor {
  id               String         @id @default(cuid())
  idcima           String?        @map("idcima")
  rif              String?        @unique
  nombre           String
  region           String?
  estado           String?
  municipio        String?
  personaContacto  String?        @map("persona_contacto")
  direccion        String?
  telefonoPersonal String?        @map("telefono_personal")
  telefonoFijo     String?        @map("telefono_fijo")
  email            String?
  isActive         Boolean        @default(true)
  ordenes          OrdenCompra[]
  createdAt        DateTime       @default(now())

  @@map("proveedores")
}

model OrdenCompra {
  id          String          @id @default(cuid())
  numero      String          @unique
  proveedorId String
  proveedor   Proveedor       @relation(fields: [proveedorId], references: [id])
  estado      String          @default("BORRADOR") // BORRADOR | EMITIDA | PENDIENTE | RECIBIDA | CANCELADA
  subtotalUSD Decimal         @db.Decimal(12, 2)
  ivaUSD      Decimal         @db.Decimal(12, 2)
  totalUSD    Decimal         @db.Decimal(12, 2)
  tasaBCV     Decimal         @db.Decimal(10, 4)
  items       ItemOrdenCompra[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("ordenes_compra")
}

model ItemOrdenCompra {
  id          String      @id @default(cuid())
  ordenId     String
  productoId  String
  cantidad    Int
  precioUSD   Decimal     @db.Decimal(12, 2)
  orden       OrdenCompra @relation(fields: [ordenId], references: [id])
  producto    Producto    @relation(fields: [productoId], references: [id])

  @@map("items_orden_compra")
}

// ─── Ventas ──────────────────────────────────────────────────────────────────

model Vendedor {
  id               String   @id @default(cuid())
  idcima           String?  @map("idcima")
  rif              String?
  nombre           String
  region           String?
  estado           String?
  municipio        String?
  personaContacto  String?  @map("persona_contacto")
  direccion        String?
  telefonoPersonal String?  @map("telefono_personal")
  telefonoFijo     String?  @map("telefono_fijo")
  email            String?
  ciudad           String?
  notas            String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  @@map("vendedores")
}

model Cliente {
  id               String    @id @default(cuid())
  idcima           String?   @map("idcima")
  rif              String?
  nombre           String
  region           String?
  estado           String?
  municipio        String?
  personaContacto  String?   @map("persona_contacto")
  direccion        String?
  telefonoPersonal String?   @map("telefono_personal")
  telefonoFijo     String?   @map("telefono_fijo")
  email            String?
  isActive         Boolean   @default(true)
  facturas         Factura[]
  createdAt        DateTime  @default(now())

  @@map("clientes")
}

model Factura {
  id          String        @id @default(cuid())
  numero      String        @unique
  clienteId   String
  cliente     Cliente       @relation(fields: [clienteId], references: [id])
  estado      String        @default("PENDIENTE") // PENDIENTE | PAGADA | VENCIDA | ANULADA
  subtotalVES Decimal       @db.Decimal(14, 2)
  ivaVES      Decimal       @db.Decimal(14, 2)
  totalVES    Decimal       @db.Decimal(14, 2)
  totalUSD    Decimal       @db.Decimal(12, 2)
  tasaBCV     Decimal       @db.Decimal(10, 4)
  items       ItemFactura[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("facturas")
}

model ItemFactura {
  id          String  @id @default(cuid())
  facturaId   String
  descripcion String
  cantidad    Int
  precioVES   Decimal @db.Decimal(12, 2)
  factura     Factura @relation(fields: [facturaId], references: [id])

  @@map("items_factura")
}

// ─── RRHH & Nómina ───────────────────────────────────────────────────────────

model Empleado {
  id            String    @id @default(cuid())
  cedula        String    @unique
  nombre        String
  apellido      String
  email         String    @unique
  cargo         String
  departamento  String
  salarioUSD    Decimal   @db.Decimal(10, 2)
  fechaIngreso  DateTime
  estado        String    @default("ACTIVO") // ACTIVO | VACACIONES | BAJA_TEMPORAL | INACTIVO
  estadoGeo     String?   @map("estado_geo")
  municipio     String?
  direccion     String?
  telefono      String?
  isActive      Boolean   @default(true)
  nominas       Nomina[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("empleados")
}

model Nomina {
  id            String   @id @default(cuid())
  empleadoId    String
  empleado      Empleado @relation(fields: [empleadoId], references: [id])
  periodo       String   // e.g. "2024-10-01"
  salarioBruto  Decimal  @db.Decimal(10, 2)
  ivss          Decimal  @db.Decimal(10, 2)
  faov          Decimal  @db.Decimal(10, 2)
  inces         Decimal  @db.Decimal(10, 2)
  islr          Decimal  @db.Decimal(10, 2)
  salarioNeto   Decimal  @db.Decimal(10, 2)
  tasaBCV       Decimal  @db.Decimal(10, 4)
  createdAt     DateTime @default(now())

  @@map("nominas")
}

// ─── Producción ──────────────────────────────────────────────────────────────

model OrdenProduccion {
  id          String               @id @default(cuid())
  numero      String               @unique
  estado      String               @default("PLANIFICADA") // PLANIFICADA | EN_PROCESO | COMPLETADA | CANCELADA
  progreso    Int                  @default(0)
  fechaInicio DateTime
  fechaFin    DateTime
  items       ItemOrdenProduccion[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@map("ordenes_produccion")
}

model ItemOrdenProduccion {
  id        String          @id @default(cuid())
  ordenId   String
  productoId String
  cantidad  Int
  orden     OrdenProduccion @relation(fields: [ordenId], references: [id])
  producto  Producto        @relation(fields: [productoId], references: [id])

  @@map("items_orden_produccion")
}

// ─── Geografía Venezuela ─────────────────────────────────────────────────────

model GeoRegion {
  id       String      @id @default(cuid())
  nombre   String      @unique
  estados  GeoEstado[]

  @@map("geo_regiones")
}

model GeoEstado {
  id          String         @id @default(cuid())
  nombre      String
  regionId    String
  region      GeoRegion      @relation(fields: [regionId], references: [id])
  municipios  GeoMunicipio[]

  @@unique([nombre, regionId])
  @@map("geo_estados")
}

model GeoMunicipio {
  id        String    @id @default(cuid())
  nombre    String
  estadoId  String
  estado    GeoEstado @relation(fields: [estadoId], references: [id])

  @@unique([nombre, estadoId])
  @@map("geo_municipios")
}

// ─── Configuración ───────────────────────────────────────────────────────────

model Configuracion {
  id          String   @id @default(cuid())
  clave       String   @unique
  valor       String
  descripcion String?
  updatedAt   DateTime @updatedAt

  @@map("configuracion")
}

model TasaBCV {
  id        String   @id @default(cuid())
  tasa      Decimal  @db.Decimal(10, 4)
  fecha     DateTime @default(now())

  @@map("tasas_bcv")
}

// ─── Empresas (Tenant) ───────────────────────────────────────────────────────

model Empresa {
  id        String   @id @default(cuid())
  nombre    String
  rif       String   @unique
  email     String?
  telefono  String?
  direccion String?
  estado    String?
  municipio String?
  color     String   @default("#6366f1")
  logo      String?
  plan      String   @default("Starter")
  users     Int      @default(0)
  status    String   @default("activo")
  mrr       Int      @default(49)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  usersList User[]

  @@map("empresas")
}
