  conversation   ChatbotConversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@index([timestamp])
}

model AIPrediction {
  id         String         @id @default(cuid())
  type       PredictionType
  entityId   String?
  entityType String?
  inputData  Json
  prediction Json
  confidence Float?
  model      String?
  validFrom  DateTime
  validUntil DateTime
  accuracy   Float?
  createdAt  DateTime       @default(now())

  @@index([type])
  @@index([entityId])
  @@index([validUntil])
}

model Webhook {
  id        String       @id @default(cuid())
  name      String
  url       String
  secret    String?
  events    String[]
  isActive  Boolean      @default(true)
  headers   Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  logs      WebhookLog[]
}

