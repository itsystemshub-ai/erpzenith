# Vercel ignore file - Frontend only

# Git
.git
.gitignore

# Dependencies
node_modules

# Build outputs (se generan en cada deploy)
.next
dist
out
build

# Turbo cache
.turbo
.nx

# Environment files (CRÍTICO - nunca commitear .env reales)
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor
.vscode
.idea
*.suo
*.ntvs*
*.njsproj
*.sln

# Testing
coverage
.jest

# Prisma
prisma/*.db
prisma/*.db-journal

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Misc
.vercel
.netlify
*.md
!README.md

# Backend (no necesario en Vercel)
apps/backend/**
!apps/backend/package.json
packages/**

# Deploy configs
deploy/**
