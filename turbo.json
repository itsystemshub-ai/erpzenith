{
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": ["FRONTEND_URL"]
    },
    "generate": {
      "cache": false
    },
    "setup": {
      "dependsOn": ["generate"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {}
  }
}
