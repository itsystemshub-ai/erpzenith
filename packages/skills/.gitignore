# ERP Zenith Skills - .gitignore

# Dependencies
node_modules/
package-lock.json
pnpm-lock.yaml
bun.lock

# Output files (generated images)
output/*.png
src/imgs/*.png
src/data/*.json

# Tesseract cache
tesseract_cache/

# Logs
logs/
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables
.env
.env.local
.env.*.local

# Build outputs
dist/
build/

# Temporary files
tmp/
temp/
.cache/
